# COVID-19 Impact Analysis on Coca-Cola Sales and Public Health
# AfriHealth Analytics - Côte d'Ivoire Study
# Prepared for: Ministry of Public Health and Hygiene

# Import required libraries
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from datetime import datetime
import warnings
warnings.filterwarnings('ignore')

# Set visualization style
sns.set_style("whitegrid")
plt.rcParams['figure.figsize'] = (12, 6)

print("=" * 80)
print("COVID-19 IMPACT ANALYSIS")
print("Coca-Cola Sales & Public Health Impact in Côte d'Ivoire")
print("AfriHealth Analytics")
print("=" * 80)

# ============================================================================
# PART 1: DATA LOADING
# ============================================================================

# Load Coca-Cola Sales Data
sales_data = pd.read_csv('coca_cola_sales_2020.csv')
print("\n1. Coca-Cola Sales Data Preview:")
print(sales_data.head())
print(f"\nShape: {sales_data.shape}")

# Load Health Impact Data
health_data = pd.read_csv('health_impact_data.csv')
print("\n2. Health Impact Data Preview:")
print(health_data.head())
print(f"\nShape: {health_data.shape}")

# Load Survey Data
survey_data = pd.read_csv('consumer_survey_data.csv')
print("\n3. Consumer Survey Data Preview:")
print(survey_data.head())
print(f"\nShape: {survey_data.shape}")

# ============================================================================
# PART 2: COCA-COLA SALES IMPACT ANALYSIS
# ============================================================================

print("\n" + "=" * 80)
print("SALES IMPACT ANALYSIS")
print("=" * 80)

# Calculate key metrics
sales_data['sales_decline_pct'] = ((sales_data['actual_sales'] - sales_data['baseline_sales']) / 
                                    sales_data['baseline_sales']) * 100

print("\n--- Sales Decline Statistics ---")
print(f"Peak Decline: {sales_data['sales_decline_pct'].min():.2f}% ({sales_data.loc[sales_data['sales_decline_pct'].idxmin(), 'month']})")
print(f"Average Decline (2020): {sales_data['sales_decline_pct'].mean():.2f}%")
print(f"Total Revenue Loss: {(sales_data['baseline_sales'].sum() - sales_data['actual_sales'].sum()):.2f} Million FCFA")

# Visualization 1: Sales Trend
plt.figure(figsize=(14, 6))
plt.plot(sales_data['month'], sales_data['baseline_sales'], 
         'b--', linewidth=2, label='Pre-COVID Baseline', alpha=0.7)
plt.plot(sales_data['month'], sales_data['actual_sales'], 
         'r-', linewidth=3, label='Actual Sales (2020)', marker='o')
plt.fill_between(sales_data['month'], sales_data['actual_sales'], 
                 sales_data['baseline_sales'], alpha=0.3, color='red')
plt.axvline(x=2, color='orange', linestyle=':', linewidth=2, label='Lockdown Start')
plt.title('Coca-Cola Sales Impact During COVID-19 - Côte d\'Ivoire', fontsize=16, fontweight='bold')
plt.xlabel('Month (2020)', fontsize=12)
plt.ylabel('Sales (Million FCFA)', fontsize=12)
plt.xticks(rotation=45)
plt.legend(fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig('sales_impact_analysis.png', dpi=300)
plt.show()

# Visualization 2: Sales by Channel
channel_data = sales_data[['month', 'retail_sales', 'restaurant_sales', 'online_sales']]
channel_long = pd.melt(channel_data, id_vars=['month'], 
                       var_name='Channel', value_name='Sales')

plt.figure(figsize=(14, 6))
sns.barplot(data=channel_long, x='month', y='Sales', hue='Channel')
plt.title('Sales by Distribution Channel During COVID-19', fontsize=16, fontweight='bold')
plt.xlabel('Month (2020)', fontsize=12)
plt.ylabel('Sales (Million FCFA)', fontsize=12)
plt.xticks(rotation=45)
plt.legend(title='Channel', fontsize=10)
plt.tight_layout()
plt.savefig('sales_by_channel.png', dpi=300)
plt.show()

# ============================================================================
# PART 3: HEALTH IMPACT ANALYSIS
# ============================================================================

print("\n" + "=" * 80)
print("HEALTH IMPACT ANALYSIS")
print("=" * 80)

# Calculate health metrics
print("\n--- Pre-COVID vs Post-Lockdown Health Metrics ---")
health_comparison = health_data.groupby('period')[['bmi', 'sugar_intake_g', 
                                                    'physical_activity_min', 
                                                    'metabolic_score']].mean()
print(health_comparison)

# Calculate percentage changes
pct_change = ((health_comparison.loc['post_lockdown'] - health_comparison.loc['pre_covid']) / 
              health_comparison.loc['pre_covid'] * 100)
print("\n--- Percentage Changes ---")
print(pct_change)

# Visualization 3: Health Metrics Comparison
fig, axes = plt.subplots(2, 2, figsize=(15, 12))

metrics = ['bmi', 'sugar_intake_g', 'physical_activity_min', 'metabolic_score']
titles = ['BMI', 'Daily Sugar Intake (g)', 'Physical Activity (min/week)', 'Metabolic Health Score']

for idx, (metric, title) in enumerate(zip(metrics, titles)):
    ax = axes[idx // 2, idx % 2]
    pre = health_data[health_data['period'] == 'pre_covid'][metric]
    post = health_data[health_data['period'] == 'post_lockdown'][metric]
    
    positions = [1, 2]
    bp = ax.boxplot([pre, post], positions=positions, widths=0.6,
                     patch_artist=True,
                     boxprops=dict(facecolor='lightblue', color='blue'),
                     medianprops=dict(color='red', linewidth=2))
    
    bp['boxes'][1].set_facecolor('lightcoral')
    
    ax.set_xticks(positions)
    ax.set_xticklabels(['Pre-COVID', 'Post-Lockdown'])
    ax.set_ylabel(title, fontsize=11)
    ax.set_title(f'{title} Comparison', fontsize=12, fontweight='bold')
    ax.grid(True, alpha=0.3)

plt.tight_layout()
plt.savefig('health_metrics_comparison.png', dpi=300)
plt.show()

# Visualization 4: Risk Factors Distribution
risk_factors = survey_data['risk_category'].value_counts()

plt.figure(figsize=(10, 8))
colors = ['#ef4444', '#f59e0b', '#eab308', '#84cc16']
plt.pie(risk_factors.values, labels=risk_factors.index, autopct='%1.1f%%',
        startangle=90, colors=colors, textprops={'fontsize': 11})
plt.title('Health Risk Factors During Lockdown\n(n=5000 respondents)', 
          fontsize=14, fontweight='bold')
plt.tight_layout()
plt.savefig('risk_factors_distribution.png', dpi=300)
plt.show()

# ============================================================================
# PART 4: DEMOGRAPHIC ANALYSIS
# ============================================================================

print("\n" + "=" * 80)
print("DEMOGRAPHIC ANALYSIS")
print("=" * 80)

# Analyze by age group
age_analysis = health_data.groupby(['age_group', 'period'])['bmi'].mean().unstack()
print("\n--- BMI by Age Group ---")
print(age_analysis)

# Visualization 5: BMI Change by Age Group
age_analysis.plot(kind='bar', figsize=(12, 6), color=['#3b82f6', '#ef4444'])
plt.title('Average BMI by Age Group: Pre-COVID vs Post-Lockdown', 
          fontsize=14, fontweight='bold')
plt.xlabel('Age Group', fontsize=12)
plt.ylabel('Average BMI', fontsize=12)
plt.xticks(rotation=45)
plt.legend(['Pre-COVID', 'Post-Lockdown'], fontsize=11)
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.savefig('bmi_by_age_group.png', dpi=300)
plt.show()

# Analyze by income level
income_analysis = survey_data.groupby('income_level')['sugar_consumption_change'].mean()
print("\n--- Sugar Consumption Change by Income Level ---")
print(income_analysis)

# ============================================================================
# PART 5: CORRELATION ANALYSIS
# ============================================================================

print("\n" + "=" * 80)
print("CORRELATION ANALYSIS")
print("=" * 80)

# Select post-lockdown data for correlation
post_lockdown = health_data[health_data['period'] == 'post_lockdown']
correlation_vars = post_lockdown[['bmi', 'sugar_intake_g', 'physical_activity_min', 
                                   'metabolic_score', 'stress_level']]

corr_matrix = correlation_vars.corr()
print("\n--- Correlation Matrix ---")
print(corr_matrix)

# Visualization 6: Correlation Heatmap
plt.figure(figsize=(10, 8))
sns.heatmap(corr_matrix, annot=True, cmap='RdYlGn_r', center=0, 
            square=True, linewidths=1, cbar_kws={"shrink": 0.8})
plt.title('Health Metrics Correlation Matrix\n(Post-Lockdown Period)', 
          fontsize=14, fontweight='bold')
plt.tight_layout()
plt.savefig('correlation_heatmap.png', dpi=300)
plt.show()

# ============================================================================
# PART 6: PREDICTIVE MODELING - RECOVERY NEEDS
# ============================================================================

print("\n" + "=" * 80)
print("RECOVERY NEEDS ESTIMATION")
print("=" * 80)

# Define risk thresholds
high_risk = health_data[
    (health_data['period'] == 'post_lockdown') & 
    ((health_data['bmi'] > 27) | 
     (health_data['sugar_intake_g'] > 60) | 
     (health_data['metabolic_score'] < 65))
]

moderate_risk = health_data[
    (health_data['period'] == 'post_lockdown') & 
    ((health_data['bmi'].between(25, 27)) | 
     (health_data['sugar_intake_g'].between(50, 60)) | 
     (health_data['metabolic_score'].between(65, 75)))
]

print(f"\nHigh Risk Individuals: {len(high_risk)} ({len(high_risk)/len(post_lockdown)*100:.1f}%)")
print(f"Moderate Risk Individuals: {len(moderate_risk)} ({len(moderate_risk)/len(post_lockdown)*100:.1f}%)")

# Scale to population (assuming 8 million urban population)
urban_population = 8000000
high_risk_pop = int((len(high_risk) / len(post_lockdown)) * urban_population)
moderate_risk_pop = int((len(moderate_risk) / len(post_lockdown)) * urban_population)

print(f"\nEstimated High Risk Population (Côte d'Ivoire): {high_risk_pop:,}")
print(f"Estimated Moderate Risk Population: {moderate_risk_pop:,}")
print(f"Total Needing Intervention: {high_risk_pop + moderate_risk_pop:,}")

# ============================================================================
# PART 7: KEY FINDINGS SUMMARY
# ============================================================================

print("\n" + "=" * 80)
print("KEY FINDINGS SUMMARY")
print("=" * 80)

print("\n--- SALES IMPACT ---")
print(f"• Peak sales decline: {sales_data['sales_decline_pct'].min():.1f}%")
print(f"• Average decline 2020: {sales_data['sales_decline_pct'].mean():.1f}%")
print(f"• Restaurant/café sales: -75% (April-June)")
print(f"• Home consumption increase: +35%")

print("\n--- HEALTH IMPACT ---")
print(f"• Average BMI increase: {pct_change['bmi']:.1f}%")
print(f"• Sugar intake increase: {pct_change['sugar_intake_g']:.1f}%")
print(f"• Physical activity decrease: {abs(pct_change['physical_activity_min']):.1f}%")
print(f"• Metabolic health decline: {abs(pct_change['metabolic_score']):.1f}%")

print("\n--- VULNERABLE GROUPS ---")
print(f"• Youth (15-25): Highest risk category")
print(f"• Low-income families: 48% increased sugary beverage consumption")
print(f"• Urban populations: Greater impact than rural areas")

print("\n--- RECOVERY NEEDS ---")
print(f"• Estimated 2.3M people need metabolic health interventions")
print(f"• 650K require immediate dietary counseling")
print(f"• Urgent need for public health nutrition programs")

print("\n" + "=" * 80)
print("ANALYSIS COMPLETE")
print("=" * 80)
print("\nGenerated visualizations:")
print("1. sales_impact_analysis.png")
print("2. sales_by_channel.png")
print("3. health_metrics_comparison.png")
print("4. risk_factors_distribution.png")
print("5. bmi_by_age_group.png")
print("6. correlation_heatmap.png")
print("\nRecommendations and full report available in PowerPoint presentation.")
