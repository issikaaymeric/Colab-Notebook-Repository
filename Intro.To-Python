 nombre entre 1 et 10:5\n","Tapez un nombre entre 1 et 10:2\n","Votre nombre secret est :  10\n"]}],"source":["One = int(input(\"Tapez un nombre entre 1 et 10:\"))\n","Two = int(input(\"Tapez un nombre entre 1 et 10:\"))\n","\n","if(One \u003e= 1) and (One \u003c= 10):\n","  if(Two \u003e= 1) and (Two \u003c= 10):\n","    print(\"Votre nombre secret est : \", One * Two)\n","  else:\n","      print(\"Vous avez tapé une valeur incorrect !\")\n","else:\n","      print(\"La premiere valeur est incorrect !\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"iA_Mk-YbA2HG"},"outputs":[],"source":["print(\"1.Oueufs\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true,"base_uri":"https://localhost:8080/"},"id":"FPZaADpf10_F"},"outputs":[{"name":"stdout","output_type":"stream","text":["Too High!\n"]}],"source":["# Guesing Number\n","import random\n","def Guessing_Number():\n","    realNum = random.randint(1,100)\n","    while True:\n","\n","      players_choice = int(input('Choose your Number'))\n","\n","      if realNum \u003c players_choice :\n","        print('Too High!')\n","\n","      elif realNum \u003e players_choice:\n","        print('Too low !')\n","\n","      else:\n","        break\n","        print ('Congratulation !, well done')\n","\n","Guessing_Number()"]}],"metadata":{"colab":{"authorship_tag":"ABX9TyO/ibWJqaSm7p6pLhwhB9ak","name":"","version":""},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}